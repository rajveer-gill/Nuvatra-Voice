# Clerk Authentication (get keys from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx_or_pk_test_xxx
CLERK_SECRET_KEY=sk_live_xxx_or_sk_test_xxx

# If Clerk Dashboard uses a custom clerk.<your-domain> JS proxy and it returns 5xx, bypass by loading clerk-js from the CDN (must track @clerk/clerk-js major version — see failing browser URL in DevTools Network tab).
# NEXT_PUBLIC_CLERK_JS_URL=https://cdn.jsdelivr.net/npm/@clerk/clerk-js@5/dist/clerk.browser.js

# Redirect after sign-in/sign-up (e.g. /dashboard)
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Backend API base URL (e.g. https://your-backend.onrender.com)
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com

# Optional: Sentry browser/server error tracking (same DSN as backend or a Next-specific client DSN)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Optional: allow /sentry-example-page on production builds (e.g. staging). Otherwise only dev + Vercel Preview.
# NEXT_PUBLIC_ENABLE_SENTRY_TEST_PAGE=true

# Marketing contact form (EmailJS — used by app/api/contact/route.ts; keep private key server-only). Required on Vercel for POST /api/contact to succeed.
# EMAILJS_SERVICE_ID=
# EMAILJS_TEMPLATE_ID=
# EMAILJS_PUBLIC_KEY=
# EMAILJS_PRIVATE_KEY=
