# --- Local development (copy to .env.local) ---
# NEXT_PUBLIC_API_URL=http://localhost:8000
# Run: npm run dev  (starts backend :8000 + frontend :3000)
# Backend secrets go in backend/.env — see LOCAL-DEV.md and backend/.env.example

# Clerk Authentication (get keys from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx_or_pk_test_xxx
CLERK_SECRET_KEY=sk_live_xxx_or_sk_test_xxx

# Temporary fallback only: if https://clerk.<your-domain>/.../clerk.browser.js returns 5xx, set this jsDelivr URL (match @clerk/clerk-js major to Network tab). Fix DNS in Clerk Dashboard → Domains + your registrar, then remove this var (see AGENTS.md).
# NEXT_PUBLIC_CLERK_JS_URL=https://cdn.jsdelivr.net/npm/@clerk/clerk-js@5/dist/clerk.browser.js

# Embedded sign-in/sign-up pages (must match Dashboard → Paths in Clerk and routes under app/sign-in, app/sign-up)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Redirect after sign-in/sign-up (see Clerk docs — AFTER_SIGN_* env names are deprecated)
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# JWT template name for backend API tokens (must match Clerk Dashboard → JWT templates)
# NEXT_PUBLIC_CLERK_JWT_TEMPLATE=nuvatra-backend

# Backend API base URL — local dev: http://localhost:8000 | production: https://your-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Axios timeout for API calls (ms). Default 120000; increase if Render cold-starts often time out.
# NEXT_PUBLIC_API_TIMEOUT_MS=120000

# Same comma-separated Clerk user IDs as backend ADMIN_CLERK_USER_IDS — optional locally; recommended in production (Vercel) for server-side /admin vs /dashboard routing
# ADMIN_CLERK_USER_IDS=user_xxx,user_yyy

# Optional: Sentry browser/server error tracking (same DSN as backend or a Next-specific client DSN)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Optional: allow /sentry-example-page on production builds (e.g. staging). Otherwise only dev + Vercel Preview.
# NEXT_PUBLIC_ENABLE_SENTRY_TEST_PAGE=true

# Marketing contact form (EmailJS — app/api/contact/route.ts). Required on Vercel or POST /api/contact returns 503 email_not_configured.
# EMAILJS_SERVICE_ID=
# EMAILJS_TEMPLATE_ID=
# EMAILJS_PUBLIC_KEY=
# EMAILJS_PRIVATE_KEY=
