# Copy to backend/.env and fill in values.
# See LOCAL-DEV.md for the full local workflow.

# Required — backend will not start without some key (use a real key or placeholder for UI-only dev)
OPENAI_API_KEY=sk-your-key-here

# --- Recommended: same behavior as production (dashboard + tenants + appointments in Postgres) ---
# Option A: Local Postgres (docker compose up -d) — see LOCAL-DEV.md
# DATABASE_URL=postgresql://nuvatra:nuvatra_dev@localhost:5433/nuvatra

# Option B: Render Postgres external URL (fastest; uses production data — be careful)
# DATABASE_URL=postgresql://...

# Clerk (copy from Clerk Dashboard → API Keys; use test keys for local)
# JWKS URL is usually: https://<your-clerk-frontend-api>/.well-known/jwks.json
CLERK_JWKS_URL=
CLERK_SECRET_KEY=

# Your Clerk user id(s) for /admin (comma-separated)
ADMIN_CLERK_USER_IDS=

# CORS + invite links
FRONTEND_URL=http://localhost:3000

# Canonical public URL for Twilio webhooks (only needed for phone tests)
# PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.app

# --- Optional: phone / SMS (otherwise voice endpoints stay disabled or mocked) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# NGROK_URL=https://your-subdomain.ngrok-free.app

# --- Optional: single-tenant file mode (no DATABASE_URL, no CLERK_JWKS_URL) ---
# Loads clients/<CLIENT_ID>/config.json only — dashboard auth is not multi-tenant.
# CLIENT_ID=demo-store

# Appointment confirmation emails (optional; SMS still works without these)
# RESEND_API_KEY=re_...
# APPOINTMENT_EMAIL_FROM=appointments@your-verified-domain.com
# Or SMTP fallback: SMTP_HOST= SMTP_PORT=587 SMTP_USER= SMTP_PASSWORD=

# Stripe, Sentry, etc. — only if you need those features locally
# STRIPE_SECRET_KEY=
# SENTRY_DSN=
