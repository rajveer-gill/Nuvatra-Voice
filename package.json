{
  "name": "nuvatra-voice",
  "version": "1.0.0",
  "description": "AI Voice Receptionist for Businesses",
  "private": true,
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && python main.py",
    "dev:frontend": "next dev --hostname 0.0.0.0 --port 3000 --turbo",
    "setup:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-dev.ps1",
    "dev:check": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-check.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "cd backend && python -m pytest tests -v --tb=short",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "clean": "python backend/scripts/clean_caches.py",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.38.1",
    "@clerk/themes": "^2.4.57",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@sentry/nextjs": "^10.50.0",
    "axios": "^1.6.0",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.294.0",
    "next": "^14.0.0",
    "openai": "^4.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "eslint": "^8.54.0",
    "eslint-config-next": "^14.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.0",
    "vitest": "^2.1.9"
  }
}
